# 必填：Chrome 扩展 ID，多个 ID 用逗号分隔。可在 chrome://extensions 的扩展卡片中查看。
ALLOWED_EXTENSION_IDS=

# 默认模型 API 配置。自定义 Base URL 时必须在 popup 中同时提供对应 API Key。
MODEL_PROVIDER=openai
OPENAI_API_KEY=你的默认 API Key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=120000

# Codex CLI 模式可选配置。CODEX_MODEL 留空时使用 Codex CLI 自己的默认模型。
CODEX_MODEL=
CODEX_TIMEOUT_MS=180000
# CODEX_BINARY=/absolute/path/to/codex

# 可选：后端监听端口。插件默认请求 3000 端口。
PORT=3000
