{
  "manifest_version": 3,
  "key": "",
  "name": "知乎提问助手",
  "version": "1.0.0",
  "description": "读取当前网页内容，生成多个适合知乎讨论的问题角度。",
  "permissions": ["clipboardWrite", "storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_title": "知乎提问助手",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "serviceWorker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
